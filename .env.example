# Copy file này thành .env rồi chỉnh lại nếu cần

# SQL Server container
SA_PASSWORD=Your_strong_password123!
DB_NAME=CinemaBD

# JWT tối thiểu 32 ký tự
JWT_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_32CHARS
JWT_ISSUER=CinemaBD
JWT_AUDIENCE=CinemaBD.Client

# Public URL khi chạy local Docker
WEB_PUBLIC_URL=http://localhost:7188

# VNPAY sandbox/demo - thay bằng key của bạn nếu cần thanh toán thật
VNPAY_BASE_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=CHANGE_ME
VNPAY_HASH_SECRET=CHANGE_ME

# Google login - để CHANGE_ME nếu không dùng Google OAuth
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# Email SMTP - để CHANGE_ME nếu không dùng gửi mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_FROM_NAME=CinemaBD
SMTP_FROM_EMAIL=change-me@example.com
SMTP_PASSWORD=CHANGE_ME
