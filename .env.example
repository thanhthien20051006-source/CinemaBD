# Copy file này thành .env rồi chỉnh lại nếu cần

# SQL Server local cho Docker API. Bật TCP/IP, SQL Authentication/Mixed Mode và port 1433 trên SQL Server local.
LOCAL_SQL_CONNECTION=Server=host.docker.internal,1433;Database=CinemaBD;User Id=sa;Password=CHANGE_ME_LOCAL_SA_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=True

# SQL Server container dự phòng, chỉ dùng khi chạy profile container-db
SA_PASSWORD=Your_strong_password123!
DB_NAME=CinemaBD

# JWT tối thiểu 32 ký tự, không để bắt đầu bằng CHANGE_ME khi chạy thật
JWT_KEY=replace-with-a-long-random-local-dev-secret-at-least-32-chars
JWT_ISSUER=CinemaBD
JWT_AUDIENCE=CinemaBD.Client

# Public URL khi chạy local Docker HTTP
WEB_PUBLIC_URL=http://localhost:7188

# VNPAY sandbox/demo
VNPAY_BASE_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=CHANGE_ME
VNPAY_HASH_SECRET=CHANGE_ME

# MoMo sandbox/demo
MOMO_API_URL=https://test-payment.momo.vn/gw_payment/transactionProcessor
MOMO_ACCESS_KEY=CHANGE_ME
MOMO_SECRET_KEY=CHANGE_ME
MOMO_PARTNER_CODE=MOMO
MOMO_REQUEST_TYPE=captureMoMoWallet

# Google login - để CHANGE_ME nếu không dùng Google OAuth
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# Email SMTP - copy sang .env rồi điền Gmail/app password nếu dùng gửi mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_FROM_NAME=CinemaBD
SMTP_FROM_EMAIL=your-gmail@example.com
SMTP_PASSWORD=your-gmail-app-password
