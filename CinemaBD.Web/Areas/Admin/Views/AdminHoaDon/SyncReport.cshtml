@model CinemaBD.Web.Models.InvoiceSyncReportViewModel
@{
    ViewData["Title"] = "Kiểm tra đồng bộ hóa đơn";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-database-check"></i> Kiểm tra đồng bộ hóa đơn</h3>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="AdminHoaDon" asp-action="Index">Danh sách hóa đơn</a>
        <form method="post" asp-area="Admin" asp-controller="AdminHoaDon" asp-action="SyncData">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger"><i class="bi bi-arrow-repeat"></i> Tự đồng bộ dữ liệu</button>
        </form>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Tổng hóa đơn</div><h3>@Model.TotalInvoices</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Có vấn đề</div><h3 class="text-danger">@Model.IssueCount</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Đã chuẩn hóa HĐ</div><h3>@Model.NormalizedInvoices</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Đã chuẩn hóa TT</div><h3>@Model.NormalizedPayments</h3></div></div></div>
</div>

<div class="card">
    <div class="card-header bg-primary text-white fw-bold">Danh sách hóa đơn cần kiểm tra</div>
    <div class="card-body table-responsive">
        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>Mã HĐ</th>
                <th>Mã GD</th>
                <th>KH</th>
                <th>Trạng thái</th>
                <th>Dòng</th>
                <th>Vé</th>
                <th>Combo</th>
                <th>Vấn đề</th>
                <th>Thao tác</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Items.Any())
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.InvoiceId</td>
                        <td>@item.TransactionRef</td>
                        <td>@item.CustomerId</td>
                        <td><span class="badge bg-secondary">@item.Status</span></td>
                        <td>@item.LineCount</td>
                        <td>@item.TicketLineCount / @item.TicketCount</td>
                        <td>@item.ComboLineCount / @item.ComboBookingCount</td>
                        <td>
                            @foreach (var issue in item.Issues)
                            {
                                <span class="badge bg-warning text-dark me-1 mb-1">@issue</span>
                            }
                        </td>
                        <td><a class="btn btn-sm btn-info" asp-area="Admin" asp-controller="AdminHoaDon" asp-action="Details" asp-route-id="@item.InvoiceId">Chi tiết</a></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="9" class="text-center text-success fw-bold">Dữ liệu hóa đơn đang đồng bộ tốt.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
