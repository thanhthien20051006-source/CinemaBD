@model CinemaBD.Web.Models.AdminInvoiceListItemViewModel
@{
    Layout = null;
    var ticketLines = Model.LineItems.Where(x => string.Equals(x.LineType, "Ve", StringComparison.OrdinalIgnoreCase) || !string.IsNullOrWhiteSpace(x.TicketId)).ToList();
    if (!ticketLines.Any()) ticketLines = Model.LineItems.ToList();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>In vé - @Model.InvoiceId</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background:#f1f5f9; font-family:Segoe UI,Arial,sans-serif; }
        .toolbar { position:sticky; top:0; background:#fff; padding:12px; box-shadow:0 2px 10px rgba(0,0,0,.08); z-index:10; }
        .ticket { width:780px; margin:18px auto; background:#fff; border:2px dashed #0d6efd; border-radius:18px; overflow:hidden; page-break-inside:avoid; }
        .ticket-head { background:#0d1a59; color:#fff; padding:18px 24px; display:flex; justify-content:space-between; }
        .ticket-body { padding:22px 24px; }
        .qr { width:110px; height:110px; background:#e2e8f0; display:flex; align-items:center; justify-content:center; font-weight:700; color:#334155; }
        @@media print { .toolbar { display:none; } body { background:#fff; } .ticket { margin:12px auto; } }
    </style>
</head>
<body>
<div class="toolbar text-end">
    <a class="btn btn-secondary" href="javascript:history.back()">Quay lại</a>
    <button class="btn btn-primary" onclick="window.print()">In vé</button>
</div>

@if (ticketLines.Any())
{
    foreach (var line in ticketLines)
    {
        <div class="ticket">
            <div class="ticket-head">
                <div>
                    <h3 class="mb-0">🎬 CINEMA TICKET</h3>
                    <small>Hóa đơn: @Model.InvoiceId</small>
                </div>
                <div class="text-end">
                    <div>@Model.PaymentDate.ToString("dd/MM/yyyy HH:mm")</div>
                    <strong>@(Model.Status ?? "")</strong>
                </div>
            </div>
            <div class="ticket-body row">
                <div class="col-8">
                    <h4>@(Model.MovieTitle ?? line.ItemName)</h4>
                    <p><b>Khách hàng:</b> @(Model.CustomerName ?? "Không rõ")</p>
                    <p><b>Ngày chiếu:</b> @(Model.ShowDate.HasValue ? Model.ShowDate.Value.ToString("dd/MM/yyyy") : "")</p>
                    <p><b>Giờ bắt đầu:</b> @(Model.StartTime.HasValue ? Model.StartTime.Value.ToString(@"hh\:mm") : "")</p>
                    <p><b>Mã vé/dòng:</b> @(line.TicketId ?? line.Id.ToString())</p>
                    <p><b>Nội dung:</b> @line.ItemName</p>
                    <h5 class="text-danger">@string.Format("{0:N0} đ", line.Total)</h5>
                </div>
                <div class="col-4 d-flex flex-column align-items-end justify-content-center">
                    @{
                        var qrText = $"CinemaBD|CHECKIN|{Model.TransactionRef}|{Model.InvoiceId}|{line.TicketId}";
                        var qrUrl = "https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=" + Uri.EscapeDataString(qrText);
                    }
                    <img src="@qrUrl" alt="QR check-in" class="border rounded p-1 bg-white" style="width:150px;height:150px" />
                    <small class="mt-2 text-muted text-end">Quét QR này để check-in</small>
                    <small class="text-muted text-end">@Model.InvoiceId</small>
                    <small class="text-muted text-end">Vé: @(line.TicketId ?? line.Id.ToString())</small>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-info m-4">Hóa đơn chưa có dòng vé/combo để in.</div>
}
</body>
</html>

