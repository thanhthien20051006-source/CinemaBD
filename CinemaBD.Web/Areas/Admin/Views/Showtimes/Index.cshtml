                                        <span class="badge @(s.Status == "Cancelled" ? "bg-danger" : s.Status == "Expired" ? "bg-secondary" : s.Status == "Selling" ? "bg-success" : "bg-primary")">@(s.Status ?? "Scheduled")</span>
                                    </div>
                                    <div class="slot-title">@(s.MovieTitle ?? s.MovieId)</div>
                                    <div class="small text-muted mb-2">@string.Format("{0:N0} Ä‘", s.TicketPrice)</div>
                                    <div class="small">Trá»‘ng: <b class="text-primary">@s.AvailableSeats</b>/@s.TotalSeats</div>
                                    <div class="small text-muted">Giá»¯ @s.HeldSeats Â· BÃ¡n @s.SoldSeats Â· Check-in @s.CheckedInSeats</div>
                                    <div class="btn-group btn-group-sm w-100 mt-2">
                                        <a class="btn btn-outline-secondary" href="/booking/seats?showtimeId=@s.Id" target="_blank">Gháº¿</a>
                                        <button class="btn btn-outline-primary" onclick="openShowtimeModal('@s.Id','@s.MovieId','@s.RoomId','@s.ShowDate.ToString("yyyy-MM-dd")','@s.StartTime','@s.TicketPrice','@s.Status')" @(s.CanEdit ? "" : "disabled")>Sá»­a</button>
                                        <button class="btn btn-outline-danger" onclick="deleteShowtime('@s.Id', @s.CanDelete.ToString().ToLowerInvariant())">Há»§y</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="tab-pane fade" id="tablePane" role="tabpanel">
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light"><tr><th>MÃ£</th><th>Phim</th><th>PhÃ²ng</th><th>NgÃ y</th><th>Giá»</th><th>GiÃ¡ vÃ©</th><th>Gháº¿</th><th>Tráº¡ng thÃ¡i</th><th class="text-end">Thao tÃ¡c</th></tr></thead>
                    <tbody>
                    @if (!Model.Showtimes.Any())
                    {
