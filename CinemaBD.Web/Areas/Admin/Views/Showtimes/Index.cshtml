                        </div>
                        <div class="slot-wrap">
                            @foreach (var s in room.OrderBy(x => x.StartTime))
                            {
                                var slotClass = s.Status == "Cancelled" ? "cancelled" : s.Status == "Expired" ? "expired" : s.Status == "Selling" ? "selling" : string.Empty;
                                <div class="slot-card @slotClass">
