    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-success" onclick="openGenerateModal()"><i class="bi bi-calendar-plus"></i> Sinh lá»‹ch tá»± Ä‘á»™ng</button>
        <button class="btn btn-primary" onclick="openShowtimeModal()"><i class="bi bi-plus-circle"></i> ThÃªm suáº¥t chiáº¿u</button>
