                    }
                    @foreach (var s in Model.Showtimes)
                    {
                        var badge = s.Status == "Cancelled" ? "bg-danger" : s.Status == "Expired" ? "bg-secondary" : s.Status == "Selling" ? "bg-success" : "bg-primary";
                        <tr id="row-@s.Id">
                            <td class="fw-semibold">@s.Id</td><td>@(s.MovieTitle ?? s.MovieId)</td><td>@s.RoomName</td><td>@s.ShowDate.ToString("dd/MM/yyyy")</td><td>@s.StartTime</td><td>@string.Format("{0:N0} Ä‘", s.TicketPrice)</td>
                            <td><div class="small">Trá»‘ng: <b class="text-primary">@s.AvailableSeats</b> / @s.TotalSeats</div><div class="small text-muted">Giá»¯: @s.HeldSeats | BÃ¡n: @s.SoldSeats | Check-in: @s.CheckedInSeats</div></td>
                            <td><span class="badge @badge">@(s.Status ?? "Scheduled")</span></td>
                            <td class="text-end"><div class="btn-group"><a class="btn btn-sm btn-outline-secondary" href="/booking/seats?showtimeId=@s.Id" target="_blank" title="Xem gháº¿"><i class="bi bi-grid-3x3-gap"></i></a><button type="button" class="btn btn-sm btn-outline-primary" onclick="openShowtimeModal('@s.Id','@s.MovieId','@s.RoomId','@s.ShowDate.ToString("yyyy-MM-dd")','@s.StartTime','@s.TicketPrice','@s.Status')" @(s.CanEdit ? "" : "disabled") title="Sá»­a"><i class="bi bi-pencil-square"></i></button><button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteShowtime('@s.Id', @s.CanDelete.ToString().ToLowerInvariant())" title="XÃ³a/Há»§y"><i class="bi bi-trash"></i></button></div></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="showtimeModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content"><form id="showtimeForm">
        @Html.AntiForgeryToken()
        <div class="modal-header"><h5 class="modal-title" id="modalTitle">ThÃªm suáº¥t chiáº¿u</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body row g-3">
            <input type="hidden" name="maSuatChieu" id="maSuatChieu" />
            <div class="col-md-6"><label class="form-label">Phim</label><select name="maPhim" id="maPhim" class="form-select" required><option value="">-- Chá»n phim --</option>@foreach (var m in Model.Movies){<option value="@m.Id">@m.Title</option>}</select></div>
            <div class="col-md-6"><label class="form-label">PhÃ²ng</label><select name="maPhong" id="maPhong" class="form-select" required><option value="">-- Chá»n phÃ²ng --</option>@foreach (var r in Model.Rooms){<option value="@r.Id">@r.Name</option>}</select></div>
            <div class="col-md-3"><label class="form-label">NgÃ y chiáº¿u</label><input type="date" name="ngayChieu" id="ngayChieu" class="form-control" required /></div>
            <div class="col-md-3"><label class="form-label">Giá» báº¯t Ä‘áº§u</label><input type="time" name="gioBatDau" id="gioBatDau" class="form-control" required /></div>
            <div class="col-md-3"><label class="form-label">GiÃ¡ vÃ©</label><input type="number" name="giaVe" id="giaVe" class="form-control" min="1000" step="1000" required /></div>
            <div class="col-md-3"><label class="form-label">Tráº¡ng thÃ¡i</label><select name="trangThai" id="trangThai" class="form-select"><option value="Scheduled">Scheduled</option><option value="Selling">Selling</option><option value="Cancelled">Cancelled</option><option value="Expired">Expired</option></select></div>
            <div class="col-12"><div class="alert alert-info small mb-0">Há»‡ thá»‘ng tá»± cháº·n trÃ¹ng phÃ²ng/giá». Náº¿u suáº¥t Ä‘Ã£ cÃ³ vÃ© thÃ¬ chá»‰ cáº­p nháº­t tráº¡ng thÃ¡i.</div></div>
            <div class="col-12"><div id="showtimeMessage" class="alert d-none mb-0"></div></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ÄÃ³ng</button><button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> LÆ°u</button></div>
    </form></div></div>
</div>

<div class="modal fade" id="generateModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content"><form id="generateForm">
        @Html.AntiForgeryToken()
        <div class="modal-header"><h5 class="modal-title">Sinh lá»‹ch chiáº¿u tá»± Ä‘á»™ng</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body row g-3">
            <input type="hidden" name="movieIds" value="@allMovieIds" /><input type="hidden" name="roomIds" value="@allRoomIds" />
            <div class="col-md-3"><label class="form-label">Tá»« ngÃ y</label><input type="date" name="fromDate" class="form-control" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" required /></div>
            <div class="col-md-3"><label class="form-label">Äáº¿n ngÃ y</label><input type="date" name="toDate" class="form-control" value="@Model.SelectedDate.AddDays(6).ToString("yyyy-MM-dd")" required /></div>
            <div class="col-md-3"><label class="form-label">Khung giá»</label><input name="startTimes" class="form-control" value="08:00,14:00,20:00" required /></div>
            <div class="col-md-3"><label class="form-label">GiÃ¡ vÃ©</label><input type="number" name="ticketPrice" class="form-control" value="75000" min="1000" step="1000" required /></div>
            <div class="col-12"><div class="alert alert-warning small mb-0">Máº·c Ä‘á»‹nh sinh cho toÃ n bá»™ phim vÃ  phÃ²ng hiá»‡n cÃ³. Slot trÃ¹ng sáº½ tá»± bá» qua.</div></div>
            <div class="col-12"><div id="generateMessage" class="alert d-none mb-0"></div></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ÄÃ³ng</button><button type="submit" class="btn btn-success"><i class="bi bi-calendar-plus"></i> Sinh lá»‹ch</button></div>
    </form></div></div>
</div>

@section scripts {
<script>
let showtimeModal, generateModal;
document.addEventListener('DOMContentLoaded', () => {
    showtimeModal = new bootstrap.Modal(document.getElementById('showtimeModal'));
    generateModal = new bootstrap.Modal(document.getElementById('generateModal'));
    document.getElementById('showtimeForm').addEventListener('submit', saveShowtime);
    document.getElementById('generateForm').addEventListener('submit', generateShowtimes);
});

function openShowtimeModal(id = '', movieId = '', roomId = '', date = '@Model.SelectedDate.ToString("yyyy-MM-dd")', time = '19:00', price = '75000', status = 'Scheduled') {
    document.getElementById('modalTitle').innerText = id ? 'Cáº­p nháº­t suáº¥t chiáº¿u' : 'ThÃªm suáº¥t chiáº¿u';
    document.getElementById('maSuatChieu').value = id;
    document.getElementById('maPhim').value = movieId;
    document.getElementById('maPhong').value = roomId || '@Model.RoomId';
    document.getElementById('ngayChieu').value = date;
    document.getElementById('gioBatDau').value = String(time).substring(0,5);
    document.getElementById('giaVe').value = String(price).replace(',', '.');
    document.getElementById('trangThai').value = status || 'Scheduled';
    setMessage('showtimeMessage', '', true);
    showtimeModal.show();
}
function openGenerateModal() { setMessage('generateMessage', '', true); generateModal.show(); }
async function saveShowtime(e) {
    e.preventDefault();
    const id = document.getElementById('maSuatChieu').value;
    const url = id ? '/Admin/AdminSuatChieu/UpdateShowtimeAjax' : '/Admin/AdminSuatChieu/CreateShowtimeAjax';
    const res = await fetch(url, { method: 'POST', body: new FormData(e.target), headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    setMessage('showtimeMessage', data.message || (data.success ? 'ThÃ nh cÃ´ng' : 'KhÃ´ng lÆ°u Ä‘Æ°á»£c'), data.success);
    if (data.success) setTimeout(() => location.reload(), 700);
}
async function deleteShowtime(id, canDelete) {
    if (!confirm(canDelete ? 'XÃ³a suáº¥t chiáº¿u nÃ y?' : 'Suáº¥t Ä‘Ã£ cÃ³ vÃ©. Há»‡ thá»‘ng sáº½ chuyá»ƒn sang tráº¡ng thÃ¡i Cancelled. Tiáº¿p tá»¥c?')) return;
    const body = new FormData(); body.append('id', id);
    const res = await fetch('/Admin/AdminSuatChieu/DeleteShowtimeAjax', { method: 'POST', body, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    if (data.success) location.reload(); else alert(data.message || 'KhÃ´ng xá»­ lÃ½ Ä‘Æ°á»£c suáº¥t chiáº¿u');
}
async function generateShowtimes(e) {
    e.preventDefault();
    const res = await fetch('/Admin/AdminSuatChieu/GenerateShowtimesAjax', { method: 'POST', body: new FormData(e.target), headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    setMessage('generateMessage', data.message || (data.success ? 'ÄÃ£ sinh lá»‹ch' : 'KhÃ´ng sinh Ä‘Æ°á»£c lá»‹ch'), data.success);
    if (data.success) setTimeout(() => location.reload(), 900);
}
function setMessage(id, text, success) {
    const box = document.getElementById(id);
    if (!text) { box.className = 'alert d-none mb-0'; box.innerText = ''; return; }
    box.className = 'alert mb-0 ' + (success ? 'alert-success' : 'alert-danger');
    box.innerText = text;
}
</script>
}

