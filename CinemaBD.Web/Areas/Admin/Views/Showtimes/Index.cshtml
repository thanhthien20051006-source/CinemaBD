            <div class="showtime-calendar mb-4">
                @foreach (var room in calendarRooms)
                {
                    <div class="room-lane">
                        <div class="room-lane-header">
                            <span><i class="bi bi-door-open"></i> @room.Key.ShowDate.ToString("dd/MM/yyyy") - @room.Key.RoomName</span>
