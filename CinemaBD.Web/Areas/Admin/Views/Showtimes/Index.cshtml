@model CinemaBD.Web.Models.AdminShowtimePageViewModel
@{
    ViewData["Title"] = "Quản lý lịch chiếu";
    var allMovieIds = string.Join(",", Model.Movies.Select(x => x.Id));
    var allRoomIds = string.Join(",", Model.Rooms.Select(x => x.Id));
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h4 class="mb-1">Quản lý lịch chiếu</h4>
        <div class="text-muted small">Tạo/sửa/hủy suất chiếu, chống trùng phòng giờ, xem tình trạng ghế</div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-success" onclick="openGenerateModal()"><i class="bi bi-calendar-plus"></i> Sinh lịch tự động</button>
        <button class="btn btn-primary" onclick="openShowtimeModal()"><i class="bi bi-plus-circle"></i> Thêm suất chiếu</button>
    </div>
</div>

<form method="get" class="card mb-3">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Ngày chiếu</label>
            <input type="date" name="date" class="form-control" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Phòng</label>
            <select name="roomId" class="form-select">
                <option value="">Tất cả phòng</option>
                @foreach (var r in Model.Rooms)
                {
                    <option value="@r.Id" selected="@(r.Id == Model.RoomId)">@r.Name (@r.SeatCount ghế)</option>
                }
            </select>
        </div>
        <div class="col-md-2"><button class="btn btn-outline-primary w-100"><i class="bi bi-search"></i> Lọc</button></div>
        <div class="col-md-2"><a asp-action="Index" class="btn btn-outline-secondary w-100">Hôm nay</a></div>
    </div>
</form>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Tổng suất</div><div class="h4 mb-0">@Model.Showtimes.Count</div></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Ghế đã bán</div><div class="h4 mb-0 text-success">@Model.Showtimes.Sum(x => x.SoldSeats)</div></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Ghế đang giữ</div><div class="h4 mb-0 text-warning">@Model.Showtimes.Sum(x => x.HeldSeats)</div></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Ghế trống</div><div class="h4 mb-0 text-primary">@Model.Showtimes.Sum(x => x.AvailableSeats)</div></div></div></div>
</div>

<ul class="nav nav-pills mb-3 flex-wrap gap-1">
    <li class="nav-item"><a class="nav-link @(string.IsNullOrWhiteSpace(Model.RoomId) ? "active" : "")" asp-action="Index" asp-route-date="@Model.SelectedDate.ToString("yyyy-MM-dd")">Tất cả</a></li>
    @foreach (var r in Model.Rooms)
    {
        <li class="nav-item"><a class="nav-link @(r.Id == Model.RoomId ? "active" : "")" asp-action="Index" asp-route-roomId="@r.Id" asp-route-date="@Model.SelectedDate.ToString("yyyy-MM-dd")">@r.Name</a></li>
    }
</ul>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Mã</th><th>Phim</th><th>Phòng</th><th>Ngày</th><th>Giờ</th><th>Giá vé</th><th>Ghế</th><th>Trạng thái</th><th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Showtimes.Any())
            {
                <tr><td colspan="9" class="text-center text-muted py-4">Không có suất chiếu</td></tr>
            }
            @foreach (var s in Model.Showtimes)
            {
                var badge = s.Status == "Cancelled" ? "bg-danger" : s.Status == "Expired" ? "bg-secondary" : s.Status == "Selling" ? "bg-success" : "bg-primary";
                <tr id="row-@s.Id">
                    <td class="fw-semibold">@s.Id</td>
                    <td>@(s.MovieTitle ?? s.MovieId)</td>
                    <td>@s.RoomName</td>
                    <td>@s.ShowDate.ToString("dd/MM/yyyy")</td>
                    <td>@s.StartTime</td>
                    <td>@string.Format("{0:N0} đ", s.TicketPrice)</td>
                    <td>
                        <div class="small">Trống: <b class="text-primary">@s.AvailableSeats</b> / @s.TotalSeats</div>
                        <div class="small text-muted">Giữ: @s.HeldSeats | Bán: @s.SoldSeats | Check-in: @s.CheckedInSeats</div>
                    </td>
                    <td><span class="badge @badge">@(s.Status ?? "Scheduled")</span></td>
                    <td class="text-end">
                        <div class="btn-group">
                            <a class="btn btn-sm btn-outline-secondary" href="/booking/seats?showtimeId=@s.Id" target="_blank" title="Xem ghế"><i class="bi bi-grid-3x3-gap"></i></a>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="openShowtimeModal('@s.Id','@s.MovieId','@s.RoomId','@s.ShowDate.ToString("yyyy-MM-dd")','@s.StartTime','@s.TicketPrice','@s.Status')" @(s.CanEdit ? "" : "disabled") title="Sửa"><i class="bi bi-pencil-square"></i></button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteShowtime('@s.Id', @s.CanDelete.ToString().ToLowerInvariant())" title="Xóa/Hủy"><i class="bi bi-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="showtimeModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form id="showtimeForm">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h5 class="modal-title" id="modalTitle">Thêm suất chiếu</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body row g-3">
                    <input type="hidden" name="maSuatChieu" id="maSuatChieu" />
                    <div class="col-md-6"><label class="form-label">Phim</label><select name="maPhim" id="maPhim" class="form-select" required><option value="">-- Chọn phim --</option>@foreach (var m in Model.Movies){<option value="@m.Id">@m.Title</option>}</select></div>
                    <div class="col-md-6"><label class="form-label">Phòng</label><select name="maPhong" id="maPhong" class="form-select" required><option value="">-- Chọn phòng --</option>@foreach (var r in Model.Rooms){<option value="@r.Id">@r.Name</option>}</select></div>
                    <div class="col-md-3"><label class="form-label">Ngày chiếu</label><input type="date" name="ngayChieu" id="ngayChieu" class="form-control" required /></div>
                    <div class="col-md-3"><label class="form-label">Giờ bắt đầu</label><input type="time" name="gioBatDau" id="gioBatDau" class="form-control" required /></div>
                    <div class="col-md-3"><label class="form-label">Giá vé</label><input type="number" name="giaVe" id="giaVe" class="form-control" min="1000" step="1000" required /></div>
                    <div class="col-md-3"><label class="form-label">Trạng thái</label><select name="trangThai" id="trangThai" class="form-select"><option value="Scheduled">Scheduled</option><option value="Selling">Selling</option><option value="Cancelled">Cancelled</option><option value="Expired">Expired</option></select></div>
                    <div class="col-12"><div class="alert alert-info small mb-0">Hệ thống tự chặn trùng phòng/giờ. Nếu suất đã có vé thì chỉ cập nhật trạng thái.</div></div>
                    <div class="col-12"><div id="showtimeMessage" class="alert d-none mb-0"></div></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button><button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu</button></div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="generateModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form id="generateForm">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h5 class="modal-title">Sinh lịch chiếu tự động</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body row g-3">
                    <input type="hidden" name="movieIds" value="@allMovieIds" />
                    <input type="hidden" name="roomIds" value="@allRoomIds" />
                    <div class="col-md-3"><label class="form-label">Từ ngày</label><input type="date" name="fromDate" class="form-control" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" required /></div>
                    <div class="col-md-3"><label class="form-label">Đến ngày</label><input type="date" name="toDate" class="form-control" value="@Model.SelectedDate.AddDays(6).ToString("yyyy-MM-dd")" required /></div>
                    <div class="col-md-3"><label class="form-label">Khung giờ</label><input name="startTimes" class="form-control" value="08:00,14:00,20:00" required /></div>
                    <div class="col-md-3"><label class="form-label">Giá vé</label><input type="number" name="ticketPrice" class="form-control" value="75000" min="1000" step="1000" required /></div>
                    <div class="col-12"><div class="alert alert-warning small mb-0">Mặc định sinh cho toàn bộ phim và phòng hiện có. Slot trùng sẽ tự bỏ qua.</div></div>
                    <div class="col-12"><div id="generateMessage" class="alert d-none mb-0"></div></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button><button type="submit" class="btn btn-success"><i class="bi bi-calendar-plus"></i> Sinh lịch</button></div>
            </form>
        </div>
    </div>
</div>

@section scripts {
<script>
let showtimeModal, generateModal;
document.addEventListener('DOMContentLoaded', () => {
    showtimeModal = new bootstrap.Modal(document.getElementById('showtimeModal'));
    generateModal = new bootstrap.Modal(document.getElementById('generateModal'));
    document.getElementById('showtimeForm').addEventListener('submit', saveShowtime);
    document.getElementById('generateForm').addEventListener('submit', generateShowtimes);
});

function openShowtimeModal(id = '', movieId = '', roomId = '', date = '@Model.SelectedDate.ToString("yyyy-MM-dd")', time = '19:00', price = '75000', status = 'Scheduled') {
    document.getElementById('modalTitle').innerText = id ? 'Cập nhật suất chiếu' : 'Thêm suất chiếu';
    document.getElementById('maSuatChieu').value = id;
    document.getElementById('maPhim').value = movieId;
    document.getElementById('maPhong').value = roomId || '@Model.RoomId';
    document.getElementById('ngayChieu').value = date;
    document.getElementById('gioBatDau').value = String(time).substring(0,5);
    document.getElementById('giaVe').value = String(price).replace(',', '.');
    document.getElementById('trangThai').value = status || 'Scheduled';
    setMessage('showtimeMessage', '', true);
    showtimeModal.show();
}

function openGenerateModal() {
    setMessage('generateMessage', '', true);
    generateModal.show();
}

async function saveShowtime(e) {
    e.preventDefault();
    const id = document.getElementById('maSuatChieu').value;
    const url = id ? '/Admin/AdminSuatChieu/UpdateShowtimeAjax' : '/Admin/AdminSuatChieu/CreateShowtimeAjax';
    const res = await fetch(url, { method: 'POST', body: new FormData(e.target), headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    setMessage('showtimeMessage', data.message || (data.success ? 'Thành công' : 'Không lưu được'), data.success);
    if (data.success) setTimeout(() => location.reload(), 700);
}

async function deleteShowtime(id, canDelete) {
    if (!confirm(canDelete ? 'Xóa suất chiếu này?' : 'Suất đã có vé. Hệ thống sẽ chuyển sang trạng thái Cancelled. Tiếp tục?')) return;
    const body = new FormData(); body.append('id', id);
    const res = await fetch('/Admin/AdminSuatChieu/DeleteShowtimeAjax', { method: 'POST', body, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    if (data.success) location.reload(); else alert(data.message || 'Không xử lý được suất chiếu');
}

async function generateShowtimes(e) {
    e.preventDefault();
    const res = await fetch('/Admin/AdminSuatChieu/GenerateShowtimesAjax', { method: 'POST', body: new FormData(e.target), headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    setMessage('generateMessage', data.message || (data.success ? 'Đã sinh lịch' : 'Không sinh được lịch'), data.success);
    if (data.success) setTimeout(() => location.reload(), 900);
}

function setMessage(id, text, success) {
    const box = document.getElementById(id);
    if (!text) { box.className = 'alert d-none mb-0'; box.innerText = ''; return; }
    box.className = 'alert mb-0 ' + (success ? 'alert-success' : 'alert-danger');
    box.innerText = text;
}
</script>
}
