@model CinemaBD.Web.Models.AdminShowtimeSeatMapViewModel
@{
    ViewData["Title"] = "Sơ đồ ghế suất chiếu";
    var rows = Model.Seats
        .GroupBy(x => x.Row)
        .OrderBy(g => g.Key)
        .ToList();
}

<style>
    .seat-map { display: grid; gap: .55rem; }
    .seat-row { display: flex; align-items: center; gap: .45rem; }
    .seat-row-label { width: 34px; font-weight: 800; color: #64748b; text-align: center; }
    .admin-seat { width: 46px; height: 42px; border-radius: 10px; border: 1px solid #cbd5e1; background: #f8fafc; font-size: .78rem; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; position: relative; }
    .admin-seat.vip { border-color: #f59e0b; background: #fffbeb; color: #92400e; }
    .admin-seat.held { border-color: #f59e0b; background: #fef3c7; color: #92400e; }
    .admin-seat.sold { border-color: #ef4444; background: #fee2e2; color: #991b1b; }
    .admin-seat.checked-in { border-color: #16a34a; background: #dcfce7; color: #166534; }
    .admin-seat.d-none { display: none !important; }
    .seat-row.d-none { display: none !important; }
    .screen { height: 42px; border-radius: 0 0 50% 50%; background: linear-gradient(90deg,#111827,#64748b,#111827); color: white; display:flex; align-items:center; justify-content:center; letter-spacing: .2rem; font-weight: 800; margin-bottom: 1.5rem; }
    @@media print {
        .sidebar, .navbar, .btn, .no-print { display: none !important; }
        .card { border: 0 !important; box-shadow: none !important; }
        .admin-seat { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 no-print">
    <div>
        <h4 class="mb-1">Sơ đồ ghế suất chiếu</h4>
        <div class="text-muted small">Admin xem nhanh trạng thái ghế theo từng suất chiếu</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-route-date="@Model.ShowDate.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại lịch</a>
        <button class="btn btn-outline-dark" onclick="window.print()"><i class="bi bi-printer"></i> In sơ đồ</button>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-center">
            <div class="col-md-5">
                <div class="text-muted small">Phim</div>
                <div class="h5 mb-0">@Model.MovieTitle</div>
            </div>
            <div class="col-md-2">
                <div class="text-muted small">Ngày / giờ</div>
                <div class="fw-bold">@Model.ShowDate.ToString("dd/MM/yyyy") @Model.StartTime</div>
            </div>
            <div class="col-md-2">
                <div class="text-muted small">Phòng</div>
                <div class="fw-bold">@Model.RoomName</div>
            </div>
            <div class="col-md-2">
                <div class="text-muted small">Trạng thái</div>
                <span class="badge bg-primary">@(string.IsNullOrWhiteSpace(Model.Status) ? "Scheduled" : Model.Status)</span>
            </div>
            <div class="col-md-1 text-md-end">
                <div class="text-muted small">Mã</div>
                <div class="fw-bold small">@Model.ShowtimeId</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Tổng ghế</div><div class="h4 mb-0">@Model.TotalSeats</div></div></div></div>
    <div class="col-md-2"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Ghế trống</div><div class="h4 mb-0 text-success">@Model.AvailableSeats</div></div></div></div>
    <div class="col-md-2"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Đang giữ</div><div class="h4 mb-0 text-warning">@Model.HeldSeats</div></div></div></div>
    <div class="col-md-2"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Đã bán</div><div class="h4 mb-0 text-danger">@Model.SoldSeats</div></div></div></div>
    <div class="col-md-2"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Check-in</div><div class="h4 mb-0 text-primary">@Model.CheckedInSeats</div></div></div></div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="no-print mb-3">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <div class="btn-group btn-group-sm flex-wrap" role="group" aria-label="Lọc trạng thái ghế">
                    <button type="button" class="btn btn-primary seat-filter-btn active" data-filter-type="all" data-filter-value="all">Tất cả</button>
                    <button type="button" class="btn btn-outline-success seat-filter-btn" data-filter-type="status" data-filter-value="Available">Trống</button>
                    <button type="button" class="btn btn-outline-warning seat-filter-btn" data-filter-type="type" data-filter-value="VIP">VIP</button>
                    <button type="button" class="btn btn-outline-warning seat-filter-btn" data-filter-type="status" data-filter-value="Held">Đang giữ</button>
                    <button type="button" class="btn btn-outline-danger seat-filter-btn" data-filter-type="status" data-filter-value="Sold">Đã bán</button>
                    <button type="button" class="btn btn-outline-primary seat-filter-btn" data-filter-type="status" data-filter-value="CheckedIn">Check-in</button>
                </div>
                <div class="ms-md-auto" style="min-width:220px">
                    <input type="search" id="seatSearch" class="form-control form-control-sm" placeholder="Tìm mã ghế: A1, B5..." />
                </div>
                <div class="text-muted small" id="seatFilterCount"></div>
            </div>
        </div>
        <div class="screen">MÀN HÌNH</div>
        @if (!Model.Seats.Any())
        {
            <div class="text-center text-muted py-5">Không có dữ liệu ghế cho suất chiếu này.</div>
        }
        else
        {
            <div class="seat-map">
                @foreach (var row in rows)
                {
                    <div class="seat-row" data-seat-row="@row.Key">
                        <div class="seat-row-label">@row.Key</div>
                        @foreach (var seat in row.OrderBy(x => x.Column))
                        {
                            var status = string.IsNullOrWhiteSpace(seat.Status) ? (seat.IsBooked ? "Sold" : "Available") : seat.Status;
                            var isVip = string.Equals(seat.SeatType, "VIP", StringComparison.OrdinalIgnoreCase);
                            var statusClass = status.Equals("CheckedIn", StringComparison.OrdinalIgnoreCase) ? "checked-in" : status.ToLowerInvariant();
                            var label = status.Equals("Held", StringComparison.OrdinalIgnoreCase) ? "Đang giữ"
                                : status.Equals("Sold", StringComparison.OrdinalIgnoreCase) ? "Đã bán"
                                : status.Equals("CheckedIn", StringComparison.OrdinalIgnoreCase) ? "Đã check-in"
                                : "Trống";
                            var seatClass = status.Equals("Available", StringComparison.OrdinalIgnoreCase) && isVip ? "vip" : statusClass;
                            <div class="admin-seat @seatClass" data-status="@status" data-seat-type="@seat.SeatType" data-seat-code="@(seat.Row)@(seat.Column)" title="@seat.Row@seat.Column - @seat.SeatType - @label">
                                @seat.Row@seat.Column
                            </div>
                        }
                    </div>
                }
            </div>
        }
        <div class="d-flex gap-3 flex-wrap mt-4 small">
            <span><span class="admin-seat" style="width:24px;height:22px"></span> Trống</span>
            <span><span class="admin-seat vip" style="width:24px;height:22px"></span> VIP trống</span>
            <span><span class="admin-seat held" style="width:24px;height:22px"></span> Đang giữ</span>
            <span><span class="admin-seat sold" style="width:24px;height:22px"></span> Đã bán</span>
            <span><span class="admin-seat checked-in" style="width:24px;height:22px"></span> Đã check-in</span>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const seats = Array.from(document.querySelectorAll(".admin-seat[data-seat-code]"));
            const rows = Array.from(document.querySelectorAll(".seat-row[data-seat-row]"));
            const buttons = Array.from(document.querySelectorAll(".seat-filter-btn"));
            const search = document.getElementById("seatSearch");
            const count = document.getElementById("seatFilterCount");
            let activeType = "all";
            let activeValue = "all";

            const normalize = value => (value || "").toString().trim().toLowerCase();

            function applyFilter() {
                const keyword = normalize(search?.value);
                let visible = 0;

                seats.forEach(seat => {
                    const status = normalize(seat.dataset.status);
                    const seatType = normalize(seat.dataset.seatType);
                    const code = normalize(seat.dataset.seatCode);
                    const filterValue = normalize(activeValue);

                    const matchFilter = activeType === "all"
                        || (activeType === "status" && status === filterValue)
                        || (activeType === "type" && seatType === filterValue);
                    const matchSearch = !keyword || code.includes(keyword);
                    const show = matchFilter && matchSearch;

                    seat.classList.toggle("d-none", !show);
                    if (show) visible++;
                });

                rows.forEach(row => {
                    const hasVisibleSeat = Array.from(row.querySelectorAll(".admin-seat[data-seat-code]")).some(seat => !seat.classList.contains("d-none"));
                    row.classList.toggle("d-none", !hasVisibleSeat);
                });

                if (count) count.textContent = `Hiển thị ${visible}/${seats.length} ghế`;
            }

            buttons.forEach(button => {
                button.addEventListener("click", () => {
                    activeType = button.dataset.filterType || "all";
                    activeValue = button.dataset.filterValue || "all";
                    buttons.forEach(btn => {
                        btn.classList.remove("active", "btn-primary");
                        if (!btn.className.includes("btn-outline")) btn.classList.add("btn-outline-secondary");
                    });
                    button.classList.add("active", "btn-primary");
                    button.classList.remove("btn-outline-secondary", "btn-outline-success", "btn-outline-warning", "btn-outline-danger", "btn-outline-primary");
                    applyFilter();
                });
            });

            search?.addEventListener("input", applyFilter);
            applyFilter();
        })();
    </script>
}
