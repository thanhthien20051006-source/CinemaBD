@model CinemaBD.Web.Models.AdminSeatPageViewModel
@{
    ViewData["Title"] = "Danh sách ghế";
    var i = 1;
    string HangCot(string id) => string.IsNullOrWhiteSpace(id) || id.Length < 2 ? "" : $"Hàng {id[0]}, Cột {id.Substring(1)}";
}

<div class="card sys-card mt-3">
    <div class="card-header border-0 pb-0">
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item"><a class="nav-link active" asp-area="Admin" asp-controller="AdminGhe" asp-action="Index">Danh sách ghế</a></li>
            <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="AdminGhe" asp-action="SoDo" asp-route-maPhong="@Model.RoomId">Sơ đồ ghế</a></li>
        </ul>
    </div>
    <div class="card-body">
        <h6 class="card-title mb-3">Quản lý ghế</h6>
        <form method="get" asp-area="Admin" asp-controller="AdminGhe" asp-action="Index" class="row g-2 mb-3">
            <div class="col-md-3">
                <select name="maPhong" class="form-select" onchange="this.form.submit()">
                    <option value="">Tất cả phòng</option>
                    @foreach (var room in Model.Rooms)
                    {
                        <option value="@room.Id" selected="@(room.Id == Model.RoomId)">@room.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-5">
                <div class="input-group">
                    <input name="search" value="@Model.Search" class="form-control" placeholder="Tìm theo mã ghế hoặc mã phòng..." />
                    <button class="btn btn-primary"><i class="bi bi-search"></i> Tìm kiếm</button>
                </div>
            </div>
            <div class="col-md-2">
                <a class="btn btn-outline-secondary w-100" asp-area="Admin" asp-controller="AdminGhe" asp-action="SoDo" asp-route-maPhong="@Model.RoomId">Sơ đồ</a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                <tr><th style="width:60px">#</th><th>Tên ghế</th><th>Phòng</th><th>Hàng/Cột</th><th>Loại ghế</th><th style="width:140px">Tình trạng</th></tr>
                </thead>
                <tbody>
                @if (Model.Seats.Any())
                {
                    foreach (var g in Model.Seats)
                    {
                        var isActive = !g.IsBooked;
                        <tr>
                            <td>@i</td>
                            <td>@g.Id</td>
                            <td>@(g.RoomName ?? g.RoomId)</td>
                            <td>@HangCot(g.Id.Contains('-') ? g.Id.Split('-').Last() : g.Id)</td>
                            <td>@g.SeatType</td>
                            <td>
                                <form asp-area="Admin" asp-controller="AdminGhe" asp-action="ToggleTrangThai" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@g.Id" />
                                    <input type="hidden" name="maPhong" value="@(Model.RoomId ?? g.RoomId)" />
                                    <button class="btn btn-sm @(isActive ? "btn-success" : "btn-warning")">@(isActive ? "Hoạt động" : "Khóa")</button>
                                </form>
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted">Chưa có dữ liệu ghế.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

