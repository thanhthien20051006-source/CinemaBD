@model CinemaBD.Web.Models.RolePermissionPageViewModel
@{
    ViewData["Title"] = "Phân quyền";
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <h4 class="mb-3">Phân quyền chức vụ</h4>
        <div class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label fw-bold">Chọn chức vụ</label>
                <select id="roleSelector" class="form-select" onchange="location.href='?roleId=' + this.value">
                    @foreach (var r in Model.Roles)
                    {
                        <option value="@r.Id" selected="@(r.Id == Model.SelectedRoleId)">@r.Name</option>
                    }
                </select>
            </div>
            @if (Model.Roles.FirstOrDefault(x => x.Id == Model.SelectedRoleId)?.IsMaster == true)
            {
                <div class="col-md-6">
                    <div class="alert alert-warning mb-0 py-2">
                        <i class="bi bi-shield-fill-check"></i> Chức vụ này có quyền <strong>Master</strong> (Toàn quyền hệ thống).
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-success text-white">Quyền đã gán</div>
            <div class="list-group list-group-flush">
                @if (!Model.AssignedPermissions.Any())
                {
                    <div class="p-4 text-center text-muted">Chưa gán quyền nào</div>
                }
                @foreach (var p in Model.AssignedPermissions)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-bold">@p.Name</div>
                        </div>
                        <form asp-action="Remove" method="post">
                            <input type="hidden" name="roleId" value="@Model.SelectedRoleId" />
                            <input type="hidden" name="permissionId" value="@p.Id" />
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-x-circle"></i> Gỡ</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-primary text-white">Tất cả quyền hệ thống</div>
            <div class="list-group list-group-flush">
                @foreach (var p in Model.AllPermissions)
                {
                    var isAssigned = Model.AssignedPermissions.Any(x => x.Id == p.Id);
                    <div class="list-group-item d-flex justify-content-between align-items-center @(isAssigned ? "bg-light opacity-75" : "")">
                        <div>
                            <div class="fw-bold">@p.Name</div>
                        </div>
                        @if (!isAssigned)
                        {
                            <form asp-action="Assign" method="post">
                                <input type="hidden" name="roleId" value="@Model.SelectedRoleId" />
                                <input type="hidden" name="permissionId" value="@p.Id" />
                                <button class="btn btn-sm btn-outline-primary"><i class="bi bi-plus-circle"></i> Gán</button>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-success"><i class="bi bi-check-lg"></i> Đã gán</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

