@model IEnumerable<CinemaBD.Web.Models.AdminArticleViewModel>
@{
    ViewData["Title"] = "Góc điện ảnh";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Quản lý bài viết / Góc điện ảnh</h4>
    <button class="btn btn-primary" onclick="openArticleModal()"><i class="bi bi-plus-circle"></i> Thêm bài viết</button>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th style="width: 100px;">Ảnh</th><th>Tiêu đề</th><th>Tóm tắt</th><th class="text-end" style="width: 120px;">Thao tác</th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr id="row-@item.Id">
                        <td><img src="@item.ImageUrl" class="rounded" style="width: 80px; height: 50px; object-fit: cover;" onerror="this.src='https://placehold.co/80x50?text=No+Image'" /></td>
                        <td class="fw-bold">@item.Title</td>
                        <td><div class="text-truncate" style="max-width: 300px;">@item.Summary</div></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" onclick="editArticle(@item.Id)"><i class="bi bi-pencil-square"></i></button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteArticle(@item.Id)" title="Gỡ bài viết"><i class="bi bi-eye-slash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="articleModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form id="articleForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Bài viết</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body row g-3">
                    <input type="hidden" name="Id" id="Id" />
                    <div class="col-12">
                        <label class="form-label">Tiêu đề</label>
                        <input name="Title" id="Title" class="form-control" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Tóm tắt</label>
                        <input name="Summary" id="Summary" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Link ảnh (URL)</label>
                        <input name="ImageUrl" id="ImageUrl" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Nội dung</label>
                        <textarea name="Content" id="Content" class="form-control" rows="6"></textarea>
                    </div>
                    <div class="col-12"><div id="articleMessage" class="alert d-none mb-0"></div></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
<script>
let articleModal;
document.addEventListener('DOMContentLoaded', () => {
    articleModal = new bootstrap.Modal(document.getElementById('articleModal'));
    document.getElementById('articleForm').addEventListener('submit', saveArticle);
});

function openArticleModal() {
    document.getElementById('modalTitle').innerText = 'Thêm bài viết';
    document.getElementById('articleForm').reset();
    document.getElementById('Id').value = '0';
    setArticleMessage('', true);
    articleModal.show();
}

async function editArticle(id) {
    const res = await fetch('/Admin/AdminGocDienAnh/Get/' + id, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    if (!res.ok) { alert('Lỗi'); return; }
    const d = await res.json();
    document.getElementById('modalTitle').innerText = 'Cập nhật bài viết';
    document.getElementById('Id').value = d.id;
    document.getElementById('Title').value = d.title;
    document.getElementById('Summary').value = d.summary || '';
    document.getElementById('ImageUrl').value = d.imageUrl || '';
    document.getElementById('Content').value = d.content || '';
    setArticleMessage('', true);
    articleModal.show();
}

async function saveArticle(e) {
    e.preventDefault();
    const res = await fetch('/Admin/AdminGocDienAnh/SaveAjax', { method: 'POST', body: new FormData(e.target), headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    setArticleMessage(data.message, data.success);
    if (data.success) setTimeout(() => location.reload(), 600);
}

async function deleteArticle(id) {
    if (!confirm('Gỡ bài viết này khỏi trang khách hàng?')) return;
    const res = await fetch('/Admin/AdminGocDienAnh/DeleteAjax/' + id, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    if (data.success) document.getElementById('row-' + id).remove();
    else alert(data.message);
}

function setArticleMessage(t, s) {
    const b = document.getElementById('articleMessage');
    if (!t) { b.className = 'alert d-none mb-0'; return; }
    b.className = 'alert mb-0 ' + (s ? 'alert-success' : 'alert-danger');
    b.innerText = t;
}
</script>
}

