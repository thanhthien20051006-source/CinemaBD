@{
    ViewData["Title"] = "Dashboard";
}

<h3>Xin chào, @ViewBag.AdminName</h3>

<div class="row g-3 mt-2">
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <b>Phim</b>
                <div class="fs-4 fw-bold text-primary">@ViewBag.MovieCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <b>Suất chiếu</b>
                <div class="fs-4 fw-bold text-success">@ViewBag.ShowtimeCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <b>Khách hàng</b>
                <div class="fs-4 fw-bold text-warning">@ViewBag.UserCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <b>Quản trị viên</b>
                <div class="fs-4 fw-bold text-danger">@ViewBag.BookingCount</div>
            </div>
        </div>
    </div>
</div>

<div class="alert alert-success mt-3">
    Tổng doanh thu đã thanh toán: <b>@string.Format("{0:N0}", ViewBag.TotalRevenue) đ</b>
</div>
