@{
    var fullName = Context.Session.GetString("AdminFullName") ?? "Admin";
    var roleName = Context.Session.GetString("AdminRole") ?? "Admin";
    var nav = await AdminNavigation.GetAccessAsync();
    var canSchedule = nav.Can("ghe", "phong", "suatchieu", "lichchieu");
    var canMovie = nav.Can("phim", "theloai");
    var canUser = nav.Can("khachhang", "nhanvien", "nguoidung");
    var canSystem = nav.Can("role", "chucvu", "phanquyen");
    var canContent = nav.Can("gocdienanh", "sukien", "phanhoi", "review", "noidung");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Cinema Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background: #f8f9ff; font-family: "Inter", "Segoe UI", Roboto, Arial, sans-serif; font-size: 15.5px; line-height: 1.55; text-rendering: optimizeLegibility; -webkit-font-smoothing: antialiased; }
        h1,h2,h3,h4,h5,h6,.navbar,.btn,.badge,.form-label { font-family: "Inter", "Segoe UI", Roboto, Arial, sans-serif; letter-spacing: -.01em; }
        .navbar { background: #0d1a59; }
        .navbar-brand { color: #fff !important; font-weight: 800; letter-spacing: .5px; }
        .navbar-nav .nav-link { color: #f1f1f1 !important; font-weight: 500; }
        .navbar-nav .nav-link:hover { color: #ffdd57 !important; }
        .avatar { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; }
        .card { border: none; border-radius: 12px; box-shadow: 0 4px 14px rgba(13,26,89,.10); }
        .btn-phanquyen { background: #2d6cdf; color: #fff; border: none; border-radius: 8px; padding: 5px 12px; font-weight: 600; }
        .btn-phanquyen:hover { background: #1f55c0; }
        footer { color: #777; text-align: center; padding: 18px 0; }
        .sys-link { display: flex; align-items: center; gap: 6px; }
        .sys-dd { min-width: 220px; padding: 8px; }
        .sys-dd .dropdown-item { display: flex; gap: 8px; align-items: center; }
        .sys-dd .marker { font-weight: 700; color: #64748b; }
    </style>
    @RenderSection("styles", required: false)
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark px-3">
    <a class="navbar-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">🎬 CINEMA</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="adminNav">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            @if (nav.Can("dichvu", "combo"))
            {
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="AdminDichVu" asp-action="Index"><i class="bi bi-controller"></i> Dịch Vụ</a></li>
            }
            @if (nav.Can("voucher", "khuyenmai", "combo"))
            {
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Voucher" asp-action="Index"><i class="bi bi-ticket-detailed"></i> Voucher</a></li>
            }
            @if (nav.Can("thongke", "doanhthu", "baocao"))
            {
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="AdminThongKe" asp-action="Index"><i class="bi bi-graph-up"></i> Thống Kê</a></li>
            }

            @if (canSchedule)
            {
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle sys-link" href="#" id="scheduleMenu" role="button" data-bs-toggle="dropdown"><i class="bi bi-calendar2-week"></i> Lịch chiếu</a>
                    <ul class="dropdown-menu shadow sys-dd" aria-labelledby="scheduleMenu">
                        @if (nav.Can("rap", "cinema", "phong")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="AdminRap" asp-action="Index"><span class="marker">›</span> Rạp</a></li> }
                        @if (nav.Can("ghe")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="AdminGhe" asp-action="Index"><span class="marker">›</span> Ghế</a></li> }
                        @if (nav.Can("phong")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="AdminPhong" asp-action="Index"><span class="marker">›</span> Phòng</a></li> }
                        @if (nav.Can("suatchieu", "lichchieu")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="Showtimes" asp-action="Index"><span class="marker">›</span> Suất chiếu</a></li> }
                    </ul>
                </li>
            }

            @if (canMovie)
            {
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle sys-link" href="#" id="movieMenu" role="button" data-bs-toggle="dropdown"><i class="bi bi-film"></i> Quản lý phim</a>
                    <ul class="dropdown-menu shadow sys-dd" aria-labelledby="movieMenu">
                        @if (nav.Can("phim")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="Movies" asp-action="Index"><span class="marker">›</span> Phim</a></li> }
                        @if (nav.Can("theloai")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="TheLoai" asp-action="Index"><span class="marker">›</span> Thể loại</a></li> }
                    </ul>
                </li>
            }

            @if (canUser)
            {
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle sys-link" href="#" id="userMenu" role="button" data-bs-toggle="dropdown"><i class="bi bi-people"></i> Người Dùng</a>
                    <ul class="dropdown-menu shadow sys-dd" aria-labelledby="userMenu">
                        @if (nav.Can("khachhang", "nguoidung")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="Index"><span class="marker">›</span> Khách Hàng</a></li> }
                        @if (nav.Can("tichdiem", "khachhang", "nguoidung")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="LoyaltyPoints" asp-action="Index"><span class="marker">›</span> Tích điểm</a></li> }
                        @if (nav.Can("nhanvien")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="NhanVien" asp-action="Index"><span class="marker">›</span> Nhân Viên</a></li> }
                    </ul>
                </li>
            }

            @if (canSystem)
            {
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle sys-link" href="#" id="sysMenu" role="button" data-bs-toggle="dropdown"><i class="bi bi-diagram-3"></i> Hệ Thống</a>
                    <ul class="dropdown-menu shadow sys-dd" aria-labelledby="sysMenu">
                        @if (nav.Can("role", "chucvu")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="Role" asp-action="Index"><span class="marker">›</span> Chức Vụ</a></li> }
                        @if (nav.Can("phanquyen")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="RolePermission" asp-action="Index"><span class="marker">›</span> Phân Quyền</a></li> }
                    </ul>
                </li>
            }

            @if (canContent)
            {
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle sys-link" href="#" id="contentMenu" role="button" data-bs-toggle="dropdown"><i class="bi bi-journal-text"></i> Quản lý nội dung</a>
                    <ul class="dropdown-menu shadow sys-dd" aria-labelledby="contentMenu">
                        @if (nav.Can("gocdienanh", "baiviet")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="AdminGocDienAnh" asp-action="Index"><span class="marker">›</span> Góc Điện Ảnh</a></li> }
                        @if (nav.Can("sukien")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="AdminSuKien" asp-action="Index"><span class="marker">›</span> Sự kiện</a></li> }
                        @if (nav.Can("phanhoi", "review", "danhgia")) { <li><a class="dropdown-item" asp-area="Admin" asp-controller="Reviews" asp-action="Index"><span class="marker">›</span> Phản hồi</a></li> }
                    </ul>
                </li>
            }

            @if (nav.Can("chitietve", "ve", "booking"))
            {
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Bookings" asp-action="Index"><i class="bi bi-ticket-perforated"></i> Chi tiết vé</a></li>
            }
            @if (nav.Can("hoadon", "invoice"))
            {
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="AdminHoaDon" asp-action="Index"><i class="bi bi-upc-scan"></i> Hóa đơn</a></li>
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="AdminHoaDon" asp-action="SyncReport"><i class="bi bi-database-check"></i> Đồng bộ HĐ</a></li>
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="AdminHoaDon" asp-action="CheckIn"><i class="bi bi-qr-code-scan"></i> Check-in QR</a></li>
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Refund" asp-action="Index"><i class="bi bi-arrow-counterclockwise"></i> Hoàn tiền</a></li>
            }
        </ul>

        <div class="dropdown d-flex align-items-center gap-2">
            <img class="avatar dropdown-toggle" src="https://i.pravatar.cc/100" data-bs-toggle="dropdown" style="cursor:pointer" />
            <div class="text-end text-white dropdown-toggle" data-bs-toggle="dropdown" style="cursor:pointer">
                <div class="fw-semibold">@fullName</div>
                <small class="opacity-75">@roleName</small>
            </div>
            <ul class="dropdown-menu dropdown-menu-end shadow">
                <li><span class="dropdown-item-text"><i class="bi bi-person-circle"></i> @fullName</span></li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form asp-area="Admin" asp-controller="AdminAccount" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</nav>

<main class="container-fluid px-4 py-3">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["SuccessMessage"]</div>
    }
    @RenderBody()
</main>

<footer>Copyright © 2025. All right reserved.</footer>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("scripts", required: false)
</body>
</html>

