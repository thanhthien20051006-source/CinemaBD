@model CinemaBD.Web.Models.AdminListPageViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">@Model.Title</h3>
    <button class="btn btn-primary" disabled>Thêm mới</button>
</div>

<div class="card">
    <div class="card-body table-responsive">
        @if (!Model.Rows.Any())
        {
            <div class="alert alert-info mb-0">
                Module đã được đưa vào menu/giao diện .NET 8. Phần dữ liệu CRUD chi tiết đang được port từ MVC5 sang service/API.
            </div>
        }
        else
        {
            <table class="table table-hover align-middle">
                <thead>
                <tr>
                    @foreach (var header in Model.Headers)
                    {
                        <th>@header</th>
                    }
                    <th class="text-end">Thao tác</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        @foreach (var cell in row)
                        {
                            <td>@cell</td>
                        }
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" disabled>Sửa</button>
                            <button class="btn btn-sm btn-outline-danger" disabled>Xóa</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>

