@model IReadOnlyList<CinemaBD.Web.Models.AdminLoyaltyPointViewModel>
<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Mã</th><th>Khách hàng</th><th>Điểm gốc</th><th>Điểm cộng</th><th>Điểm đã dùng</th><th>Còn lại</th><th>Quy đổi</th><th style="width:300px">Điều chỉnh</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.CustomerName <span class="text-muted small">(@item.CustomerId)</span></td>
            <td>@item.RewardPoints</td>
            <td class="text-success">@item.EarnedPoints</td>
            <td class="text-danger">@item.UsedPoints</td>
            <td><span class="badge bg-primary">@item.Balance điểm</span></td>
            <td>@item.PointsToMoney.ToString("N0") đ</td>
            <td>
                <form class="adjust-point-form d-flex gap-1" asp-area="Admin" asp-controller="LoyaltyPoints" asp-action="Adjust" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CustomerId" value="@item.CustomerId" />
                    <input type="number" name="Points" min="1" class="form-control form-control-sm" placeholder="Điểm" />
                    <select name="Action" class="form-select form-select-sm">
                        <option value="add">Cộng</option>
                        <option value="subtract">Trừ</option>
                    </select>
                    <button class="btn btn-sm btn-outline-primary">Lưu</button>
                </form>
            </td>
        </tr>
    }
    @if (!Model.Any())
    {
        <tr><td colspan="8" class="text-center text-muted">Chưa có dữ liệu tích điểm</td></tr>
    }
    </tbody>
</table>
