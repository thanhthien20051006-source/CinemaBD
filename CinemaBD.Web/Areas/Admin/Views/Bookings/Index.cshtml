@model IReadOnlyList<CinemaBD.Web.Models.AdminInvoiceListItemViewModel>
@{
    ViewData["Title"] = "Vé / Hóa đơn";
}

<h4>Danh sách vé / hóa đơn</h4>

<div class="table-responsive">
    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>Mã hóa đơn</th>
                <th>Giao dịch</th>
                <th>Khách hàng</th>
                <th>Phim</th>
                <th>Suất chiếu</th>
                <th>Ghế / dịch vụ</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Thời gian</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var b in Model)
        {
            var seats = b.LineItems.Where(x => !string.IsNullOrWhiteSpace(x.TicketId)).Select(x => x.ItemName).ToList();
            var combos = b.LineItems.Where(x => !string.IsNullOrWhiteSpace(x.ComboId)).Select(x => $"{x.ItemName} x{x.Quantity}").ToList();
            <tr>
                <td class="fw-semibold">@b.InvoiceId</td>
                <td>@b.TransactionRef</td>
                <td>@b.CustomerName</td>
                <td>@b.MovieTitle</td>
                <td>@(b.ShowDate?.ToString("dd/MM/yyyy") ?? "-") @b.StartTime</td>
                <td>
                    @if (seats.Any())
                    {
                        <div><b>Ghế:</b> @string.Join(", ", seats)</div>
                    }
                    @if (combos.Any())
                    {
                        <div class="text-muted small"><b>Dịch vụ:</b> @string.Join(", ", combos)</div>
                    }
                </td>
                <td>@string.Format("{0:N0} đ", b.TotalAmount)</td>
                <td>
                    <span class="badge @(b.IsCheckedIn ? "bg-info" : "bg-success")">@(b.IsCheckedIn ? "CheckedIn" : b.Status)</span>
                </td>
                <td>@b.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="9" class="text-center text-muted py-4">Chưa có vé/hóa đơn.</td></tr>
        }
        </tbody>
    </table>
</div>
