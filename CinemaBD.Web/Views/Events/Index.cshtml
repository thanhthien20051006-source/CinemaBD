@model CinemaBD.Web.Models.EventListPageViewModel
@{
    ViewData["Title"] = "Sự kiện";
}

<section class="container py-5 mt-5">
    <div class="mb-4">
        <p class="text-danger fw-semibold mb-1">BD Cinema</p>
        <h1 class="fw-bold mb-0">Sự kiện</h1>
    </div>

    @if (!Model.Events.Any())
    {
        <div class="alert alert-info">Hiện chưa có sự kiện đang diễn ra.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.Events)
            {
                <div class="col-md-6 col-lg-4">
                    <article class="card h-100 shadow-sm border-0">
                        @if (!string.IsNullOrWhiteSpace(item.ImageName))
                        {
                            <img src="@item.ImageName" class="card-img-top" alt="@item.Title" style="height:220px;object-fit:cover;" />
                        }
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@item.Title</h5>
                            <p class="text-muted small mb-2">
                                @item.StartDate.ToString("dd/MM/yyyy") - @item.EndDate.ToString("dd/MM/yyyy")
                            </p>
                            <p class="card-text text-muted">@item.Summary</p>
                        </div>
                    </article>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-controller="Events" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</section>
