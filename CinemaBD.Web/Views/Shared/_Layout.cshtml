@{
    var title = ViewData["Title"] as string ?? "BD Cinema";
    var fullName = Context.Session.GetString("FullName");
    var isLoggedIn = !string.IsNullOrWhiteSpace(Context.Session.GetString("UserToken"));
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - BD Cinema</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/legacy/Content/Site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/legacy/Content/cinema-theme.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-white shadow-sm fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-danger d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <img src="~/legacy/Content/img/logo.jpg" height="55" class="me-2" alt="BD Cinema Logo" />
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav mx-auto fw-semibold">
                    <li class="nav-item">
                        <a asp-controller="Home" asp-action="Index" class="nav-link text-dark px-3 active text-success fw-bold">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link text-dark px-3">Góc điện ảnh</a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link text-dark px-3">Sự kiện</a>
                    </li>
                </ul>

                <div class="dropdown">
                    <a class="nav-link dropdown-toggle text-dark d-flex align-items-center" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle me-1 fs-5"></i>
                        @(isLoggedIn ? (string.IsNullOrWhiteSpace(fullName) ? "Tài khoản" : fullName) : "Tài khoản")
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                        @if (isLoggedIn)
                        {
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person-lines-fill me-2"></i> Thông tin cá nhân</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="History"><i class="bi bi-ticket-perforated me-2"></i> Vé của tôi</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                        }
                        else
                        {
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-2"></i> Đăng nhập</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-2"></i> Đăng ký</a></li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <main class="app-main">
        @RenderBody()
    </main>

    <footer class="footer bg-dark text-light pt-5 pb-3">
        <div class="footer-inner container-fluid px-5">
            <div class="row gy-4">
                <div class="col-md-3">
                    <h5 class="footer-title text-danger"><i class="bi bi-film me-2"></i> CINEMA VIỆT NAM</h5>
                    <p class="small">Hệ thống rạp chiếu phim hiện đại, mang đến trải nghiệm xem phim tuyệt vời nhất cho khán giả.</p>
                </div>
                <div class="col-md-3">
                    <h6 class="footer-subtitle text-danger">THÔNG TIN CÔNG TY</h6>
                    <p class="fw-bold mb-1">CÔNG TY TNHH 3 THÀNH VIÊN CINEMA BÌNH DƯƠNG</p>
                    <p class="small mb-1"><i class="bi bi-file-earmark-text"></i> Giấy CNĐKDN: 0302575928</p>
                    <p class="small"><i class="bi bi-calendar3"></i> Đăng ký lần đầu: 02/05/2008</p>
                </div>
                <div class="col-md-3">
                    <h6 class="footer-subtitle text-danger">LIÊN HỆ</h6>
                    <p class="small mb-1"><i class="bi bi-geo-alt"></i> Tầng 3, TTTM Aeon, TP.HCM</p>
                    <p class="small mb-1"><i class="bi bi-telephone"></i> (028) 1234 5678</p>
                    <p class="small"><i class="bi bi-envelope"></i> info@cinemavn.com</p>
                </div>
                <div class="col-md-3">
                    <h6 class="footer-subtitle text-danger">LIÊN KẾT</h6>
                    <ul class="list-unstyled small mb-3">
                        <li><i class="bi bi-person-lines-fill me-1"></i> Chính Sách Khách Hàng</li>
                        <li><i class="bi bi-shield-lock me-1"></i> Chính Sách Bảo Mật</li>
                        <li><i class="bi bi-file-earmark-text me-1"></i> Điều Khoản Sử Dụng</li>
                        <li><i class="bi bi-life-preserver me-1"></i> Hỗ Trợ</li>
                    </ul>
                    <p class="fw-bold text-danger mb-2">KẾT NỐI VỚI CHÚNG TÔI</p>
                    <div class="d-flex gap-3">
                        <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
            </div>
            <hr class="border-secondary mt-4 mb-3" />
            <p class="text-center small mb-0">COPYRIGHT © @DateTime.Now.Year - CINEMAVN.COM - ALL RIGHTS RESERVED.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>

