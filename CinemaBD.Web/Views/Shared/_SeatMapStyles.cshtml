<style>
    .cinema-screen {
        max-width: 760px;
        margin: 0 auto 26px;
        padding: 11px 16px;
        text-align: center;
        color: #fff;
        font-weight: 800;
        letter-spacing: 4px;
        background: linear-gradient(90deg, #e2e8f0 0%, #64748b 45%, #334155 50%, #64748b 55%, #e2e8f0 100%);
        border-radius: 0 0 90% 90%;
        box-shadow: 0 12px 24px rgba(15, 23, 42, .18);
    }

    .cinema-seat-map {
        display: flex;
        flex-direction: column;
        gap: 12px;
        align-items: center;
        overflow-x: auto;
        padding: 4px 0 10px;
    }

    .cinema-seat-row {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: fit-content;
    }

    .cinema-row-label {
        width: 58px;
        text-align: right;
        font-weight: 800;
        color: #334155;
    }

    .cinema-row-seats {
        display: flex;
        gap: 8px;
        flex-wrap: nowrap;
    }

    .cinema-seat {
        width: 48px;
        height: 42px;
        border: 0;
        border-radius: 10px 10px 5px 5px;
        color: #fff;
        font-size: 12px;
        font-weight: 800;
        box-shadow: 0 4px 10px rgba(15, 23, 42, .18);
        transition: .15s ease;
        position: relative;
    }

    .cinema-seat::after {
        content: "";
        position: absolute;
        left: 8px;
        right: 8px;
        bottom: 4px;
        height: 3px;
        border-radius: 99px;
        background: rgba(255,255,255,.42);
    }

    .cinema-seat:not(:disabled):hover {
        transform: translateY(-2px);
        filter: brightness(1.08);
    }

    .cinema-seat-normal { background: #2563eb; }
    .cinema-seat-vip { background: #9333ea; }
    .cinema-seat-selected { background: #16a34a !important; }
    .cinema-seat-booked { background: #dc2626 !important; cursor: not-allowed; opacity: .92; }
    .cinema-seat-maintenance { background: #f59e0b !important; color: #111827; }

    .cinema-seat-legend {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .cinema-legend-pill {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 7px 12px;
        border-radius: 999px;
        background: #f8fafc;
        color: #334155;
        border: 1px solid #e2e8f0;
        font-size: 13px;
        font-weight: 700;
    }

    .cinema-legend-dot {
        width: 16px;
        height: 16px;
        border-radius: 5px 5px 2px 2px;
        display: inline-block;
    }

    .cinema-legend-normal { background:#2563eb; }
    .cinema-legend-vip { background:#9333ea; }
    .cinema-legend-selected { background:#16a34a; }
    .cinema-legend-booked { background:#dc2626; }
    .cinema-legend-maintenance { background:#f59e0b; }

    @@media (max-width: 576px) {
        .cinema-row-label { width: 34px; }
        .cinema-seat { width: 40px; height: 38px; font-size: 11px; }
        .cinema-row-seats { gap: 6px; }
    }
</style>
