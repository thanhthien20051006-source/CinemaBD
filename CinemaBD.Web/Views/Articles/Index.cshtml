@model CinemaBD.Web.Models.ArticleListPageViewModel
@{
    ViewData["Title"] = "Góc điện ảnh";
}

<section class="container py-5 mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="text-danger fw-semibold mb-1">BD Cinema</p>
            <h1 class="fw-bold mb-0">Góc điện ảnh</h1>
        </div>
    </div>

    @if (!Model.Articles.Any())
    {
        <div class="alert alert-info">Chưa có bài viết nào.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.Articles)
            {
                <div class="col-md-6 col-lg-4">
                    <article class="card h-100 shadow-sm border-0">
                        @if (!string.IsNullOrWhiteSpace(item.ImageName))
                        {
                            <img src="@item.ImageName" class="card-img-top" alt="@item.Title" style="height:220px;object-fit:cover;" />
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="small text-muted mb-2">@item.PublishedAt.ToString("dd/MM/yyyy")</div>
                            <h5 class="card-title fw-bold">@item.Title</h5>
                            <p class="card-text text-muted flex-grow-1">@item.Summary</p>
                            <a class="btn btn-outline-danger mt-2" asp-controller="Articles" asp-action="Details" asp-route-id="@item.Id">Đọc tiếp</a>
                        </div>
                    </article>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-controller="Articles" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</section>
