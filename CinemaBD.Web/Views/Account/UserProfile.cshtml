@model CinemaBD.Web.Models.UserProfileViewModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm p-3 text-center">
                <h4 class="mt-3 text-danger fw-bold">@Model.FullName</h4>
                <p class="text-muted">Tổng chi tiêu</p>
                <h5 class="text-danger fw-semibold">@String.Format("{0:N0} đ", Model.TotalSpent)</h5>

                <hr />
                <p><b>Tài khoản:</b> @Model.Username</p>
                <p><b>Email:</b> @(string.IsNullOrWhiteSpace(Model.Email) ? "Chưa cập nhật" : Model.Email)</p>
                <p><b>Số điện thoại:</b> @(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)</p>
                <p><b>Ngày sinh:</b> @(Model.BirthDate?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</p>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <ul class="nav nav-tabs mb-3" id="profileTabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#info">Thông tin cá nhân</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#history">Lịch sử hóa đơn</a>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="info">
                        <form method="post" asp-controller="Account" asp-action="Profile">
                            @Html.AntiForgeryToken()
                            <input asp-for="UserId" type="hidden" />
                            <input asp-for="TotalSpent" type="hidden" />

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label asp-for="FullName" class="form-label">Họ và tên</label>
                                    <input asp-for="FullName" class="form-control" />
                                    <span asp-validation-for="FullName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Username" class="form-label">Tài khoản</label>
                                    <input asp-for="Username" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label asp-for="Email" class="form-label">Email</label>
                                    <input asp-for="Email" class="form-control" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="PhoneNumber" class="form-label">Số điện thoại</label>
                                    <input asp-for="PhoneNumber" class="form-control" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <label asp-for="BirthDate" class="form-label">Ngày sinh</label>
                                    <input asp-for="BirthDate" type="date" class="form-control" />
                                    <span asp-validation-for="BirthDate" class="text-danger"></span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-danger px-4">
                                <i class="bi bi-save"></i> Lưu thay đổi
                            </button>
                        </form>
                    </div>

                    <div class="tab-pane fade" id="history">
                        <p class="mb-3">Xem lịch sử hóa đơn chi tiết tại trang riêng.</p>
                        <a asp-controller="Account" asp-action="History" class="btn btn-danger">Mở lịch sử hóa đơn</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

