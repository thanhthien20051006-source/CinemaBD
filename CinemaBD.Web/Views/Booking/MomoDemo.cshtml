@model CinemaBD.Web.Models.MomoDemoViewModel
@{
    ViewData["Title"] = "Demo thanh toán MoMo";
}

<section class="cinema-section py-5">
    <div class="cinema-container" style="max-width: 720px;">
        <div class="cinema-panel text-center">
            <div class="mb-3">
                <img src="https://upload.wikimedia.org/wikipedia/vi/f/fe/MoMo_Logo.png" height="72" alt="MoMo" />
            </div>

            <h2 class="cinema-title mb-2">Demo thanh toán MoMo</h2>
            <p class="cinema-muted mb-4">Bấm xác nhận để mô phỏng thanh toán thành công và tạo lịch sử đơn hàng.</p>

            <div class="cinema-summary text-start mx-auto mb-4" style="max-width: 520px;">
                <div class="d-flex justify-content-between py-2 border-bottom border-secondary">
                    <span>Mã đơn hàng</span>
                    <strong>@Model.OrderId</strong>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom border-secondary">
                    <span>Số tiền</span>
                    <strong class="text-warning">@String.Format("{0:N0} ₫", Model.Amount)</strong>
                </div>
                <div class="py-2">
                    <span>Nội dung</span>
                    <div class="fw-semibold mt-1">@Model.OrderInfo</div>
                </div>
            </div>

            <form method="post" asp-controller="Booking" asp-action="MomoDemoConfirm" class="d-inline-block">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.OrderId" />
                <input type="hidden" name="amount" value="@Model.Amount" />
                <input type="hidden" name="orderInfo" value="@Model.OrderInfo" />
                <button type="submit" class="btn btn-lg rounded-pill px-5 text-white fw-bold" style="background:#ae2070;">
                    Xác nhận thanh toán thành công
                </button>
            </form>

            <div class="mt-3">
                <a href="javascript:history.back()" class="cinema-link">Quay lại</a>
            </div>
        </div>
    </div>
</section>

