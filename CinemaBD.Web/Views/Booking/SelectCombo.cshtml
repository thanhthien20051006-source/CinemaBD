@model CinemaBD.Web.Models.ComboSelectionPageViewModel
@{
    ViewData["Title"] = "Chọn combo rạp phim";
}

<div class="cinema-page combo-page">
    <section class="cinema-hero cinema-hero-small">
        <div class="cinema-hero-bg"></div>
        <div class="cinema-hero-content">
            <span class="cinema-eyebrow"><i class="bi bi-stars"></i> Cinema Snack Bar</span>
            <h1>Chọn bắp nước cho buổi xem phim</h1>
            <p>Thêm combo yêu thích, kiểm tra ghế và tổng tiền trước khi tiếp tục đặt vé.</p>
        </div>
        <div class="cinema-seat-ticket">
            <span>Ghế</span>
            <strong>@(Model.Seats.Any() ? string.Join(", ", Model.Seats) : "--")</strong>
        </div>
    </section>

    <div class="cinema-workspace">
        <div class="cinema-work-main">
            <section class="cinema-panel">
                <div class="cinema-section-heading compact">
                    <div><span>01</span><h2>Combo bắp nước</h2></div>
                    <small>Chọn hoặc bỏ chọn combo bất kỳ</small>
                </div>

                <div class="combo-grid">
                    @if (Model.Combos.Any())
                    {
                        foreach (var combo in Model.Combos)
                        {
                            var imageUrl = string.IsNullOrWhiteSpace(combo.ImageUrl)
                                ? Url.Content("~/legacy/Content/img/combo1.jpg")
                                : (combo.ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                                    ? combo.ImageUrl
                                    : Url.Content("~/legacy/Content/img/" + combo.ImageUrl.TrimStart('/')));

                            <article class="combo-card" data-id="@combo.Id" data-price="@combo.Price">
                                <div class="combo-img-wrap">
                                    <img src="@imageUrl" alt="@combo.Name" onerror="this.src='https://placehold.co/600x400?text=Combo'" />
                                    <span class="price-badge">@combo.Price.ToString("N0") đ</span>
                                </div>
                                <div class="combo-body">
                                    <h3 class="card-title">@combo.Name</h3>
                                    <p>Combo chuẩn rạp phim, dùng kèm khi xem phim bom tấn.</p>
                                    <button type="button" class="btnSelectCombo" data-id="@combo.Id"><i class="bi bi-plus-circle"></i> Thêm combo</button>
                                </div>
                            </article>
                        }
                    }
                    else
                    {
                        <div class="cinema-empty">Không có dữ liệu combo.</div>
                    }
                </div>
            </section>

            <section class="cinema-panel">
                <div class="cinema-section-heading compact">
                    <div><span>02</span><h2>Combo đã chọn</h2></div>
                </div>
                <div id="selectedComboList"><div class="cinema-empty">Chưa chọn dịch vụ nào.</div></div>
            </section>
        </div>

        <aside class="cinema-summary">
            <div class="summary-header">
                <i class="bi bi-ticket-perforated"></i>
                <div><h3>Thông tin đặt vé</h3><p>Kiểm tra trước khi xác nhận</p></div>
            </div>

            <div class="summary-row">
                <span>Ghế đã chọn</span>
                <strong>
                    @if (Model.Seats.Any())
                    {
                        foreach (var seat in Model.Seats)
                        {
                            <span class="seat-pill">@seat</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">Chưa có</span>
                    }
                </strong>
            </div>
            <div class="summary-row"><span>Tiền vé</span><strong id="ticketPrice">@Model.TicketTotal.ToString("N0") đ</strong></div>
            <div class="summary-row"><span>Combo</span><strong id="comboTotalText">0 đ</strong></div>
            <div class="summary-total"><span>Tổng cộng</span><strong id="totalPrice">@Model.TicketTotal.ToString("N0") đ</strong></div>

            <form id="checkoutRedirectForm" method="get" asp-controller="Booking" asp-action="Checkout">
                <input type="hidden" name="showtimeId" value="@Model.ShowtimeId" />
                <input type="hidden" name="seats" id="seatsHiddenInput" value="@string.Join(",", Model.Seats)" />
                <input type="hidden" name="ticketTotal" id="ticketTotalInput" value="@Model.TicketTotal.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" />
                <input type="hidden" name="comboTotal" id="comboTotalInput" value="0" />
                <input type="hidden" name="totalAmount" id="totalAmount" value="@Model.TicketTotal.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" />
                <input type="hidden" name="combos" id="comboInput" value="" />
                <button type="submit" class="cinema-primary-btn w-100 justify-content-center">Tiếp tục đặt vé <i class="bi bi-arrow-right-circle"></i></button>
            </form>

            <a class="summary-back" asp-controller="Booking" asp-action="SelectSeats" asp-route-showtimeId="@Model.ShowtimeId"><i class="bi bi-arrow-left"></i> Quay lại chọn ghế</a>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var selectedCombos = [];
            var ticketTotal = parseFloat(document.getElementById("ticketTotalInput").value) || 0;

            document.querySelectorAll('.btnSelectCombo').forEach(function (button) {
                button.addEventListener('click', function () {
                    var id = this.getAttribute('data-id');
                    var card = this.closest('.combo-card');
                    var price = parseFloat(card.getAttribute('data-price')) || 0;
                    var name = card.querySelector('.card-title').innerText;
                    var img = card.querySelector('img').src;
                    var exists = selectedCombos.some(function (c) { return c.id === id; });

                    if (exists) {
                        selectedCombos = selectedCombos.filter(function (c) { return c.id !== id; });
                        card.classList.remove('selected');
                        this.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm combo';
                    } else {
                        selectedCombos.push({ id: id, name: name, price: price, qty: 1, img: img });
                        card.classList.add('selected');
                        this.innerHTML = '<i class="bi bi-check-circle-fill"></i> Đã thêm';
                    }

                    renderComboList();
                    updateTotal();
                });
            });

            function renderComboList() {
                var container = document.getElementById('selectedComboList');
                var comboInput = document.getElementById('comboInput');

                if (selectedCombos.length === 0) {
                    container.innerHTML = '<div class="cinema-empty">Chưa chọn dịch vụ nào.</div>';
                    comboInput.value = '';
                    return;
                }

                container.innerHTML = selectedCombos.map(function (c) {
                    return '<div class="selected-item">'
                        + '<img src="' + c.img + '" alt="' + c.name + '" />'
                        + '<div class="selected-info"><strong>' + c.name + '</strong><span>' + c.price.toLocaleString('vi-VN') + ' đ / phần</span></div>'
                        + '<div class="qty-box"><button onclick="changeQty(\'' + c.id + '\', -1);return false;">-</button><input type="text" value="' + c.qty + '" readonly /><button onclick="changeQty(\'' + c.id + '\', 1);return false;">+</button></div>'
                        + '<strong class="line-price">' + (c.price * c.qty).toLocaleString('vi-VN') + ' đ</strong>'
                        + '<button class="remove-btn" onclick="removeCombo(\'' + c.id + '\');return false;"><i class="bi bi-trash"></i></button>'
                        + '</div>';
                }).join('');

                comboInput.value = selectedCombos.map(function (c) { return c.id + ':' + c.qty; }).join(',');
            }

            window.changeQty = function (id, delta) {
                var combo = selectedCombos.find(function (x) { return x.id === id; });
                if (!combo) return;
                combo.qty = Math.max(1, combo.qty + delta);
                renderComboList();
                updateTotal();
            };

            window.removeCombo = function (id) {
                selectedCombos = selectedCombos.filter(function (c) { return c.id !== id; });
                renderComboList();
                updateTotal();
                var btn = document.querySelector(".btnSelectCombo[data-id='" + id + "']");
                var card = btn ? btn.closest('.combo-card') : null;
                if (card) card.classList.remove('selected');
                if (btn) btn.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm combo';
            };

            function updateTotal() {
                var comboTotal = selectedCombos.reduce(function (sum, c) { return sum + (c.price * c.qty); }, 0);
                var total = ticketTotal + comboTotal;
                document.getElementById('comboTotalInput').value = comboTotal;
                document.getElementById('totalAmount').value = total;
                document.getElementById('comboTotalText').innerText = comboTotal.toLocaleString('vi-VN') + ' đ';
                document.getElementById('totalPrice').innerText = total.toLocaleString('vi-VN') + ' đ';
            }
        })();
    </script>
}

