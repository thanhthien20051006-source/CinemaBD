          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van A\",\n  \"username\": \"userapi05\",\n  \"password\": \"123456\",\n  \"email\": \"userapi05@example.com\",\n  \"phoneNumber\": \"0900000005\"\n}"
            },
